# ===========================================
# CONFIGURAÇÃO DO ANALISADOR DE MATURIDADE
# ===========================================

# Provedor LLM: 'openai' ou 'groq'
# Se não fornecer, usará análise baseada em regras
LLM_PROVIDER=groq

# Chave da API da OpenAI (opcional)
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Chave da API do Groq (obrigatório se LLM_PROVIDER=groq)
# Obtenha sua chave em: https://console.groq.com/keys
GROQ_API_KEY=

# Modelo a ser usado:
# Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# OpenAI: gpt-4o-mini, gpt-4o, gpt-5.4
MODEL=llama-3.3-70b-versatile

# Temperatura para geração (0-1):
# 0.3 = mais focado e determinístico
# 0.7 = balanceamento (recomendado)
# 1.0 = mais criativo
TEMPERATURE=0.7

# Porta do servidor (não alterar para deploy)
PORT=3000

# ===========================================
# CONFIGURAÇÃO DE EMAIL (opcional)
# ===========================================
# Para enviar relatórios por email, use o Resend:
# 1. Cadastre-se em: https://resend.com
# 2. Crie uma API Key em: https://resend.com/api-keys
# 3. Adicione seu domínio ou use onboarding@resend.dev para testes
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Alternativa (descontinuada - pode não funcionar em cloud):
# Gmail: Use uma senha de aplicativo
# https://myaccount.google.com/apppasswords
# EMAIL_USER=seuemail@gmail.com
# EMAIL_PASS=suasenhaapp
