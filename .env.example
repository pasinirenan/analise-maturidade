# Configuração do Analisador de Maturidade

# OPENAI_API_KEY=your-api-key-here
# Modelo a ser usado: gpt-4o-mini (mais barato e rápido) ou gpt-4o (mais preciso)
MODEL=gpt-4o-mini

# Temperatura para geração (0-1): 0.7 é um bom balanceamento
TEMPERATURE=0.7

# Timeout em ms para requisição à API
TIMEOUT=60000
